# --- Core GCP ---
GCP_PROJECT_ID=apac-h2s
GCP_REGION=us-central1
GCP_FIRESTORE_PROJECT_ID=apac-h2s
GCP_SERVICE_ACCOUNT_EMAIL=conclave-runner@apac-h2s.iam.gserviceaccount.com

# --- Cloud SQL (Postgres - Citations) ---
CLOUD_SQL_INSTANCE_CONNECTION_NAME=apac-h2s:us-central1:postgres
CLOUD_SQL_DB_NAME=conclave_db
CLOUD_SQL_DB_USER=postgres
CLOUD_SQL_DB_PASSWORD=pass123

# --- Live Search (Tavily) ---
# Sign up at https://tavily.com for a free key
TAVILY_API_KEY=tvly-your-key-here

# --- Tool Server URLs (MCP) ---
# Used by agents to talk to Database and Search tools
MCP_DB_SERVER_URL=http://localhost:8010
MCP_SEARCH_SERVER_URL=http://localhost:8011

# --- Orchestration & UI ---
ORCHESTRATOR_URL=http://localhost:8005
GOOGLE_GENAI_USE_VERTEXAI=True
ADK_LOG_LEVEL=INFO

# Set to 'true' to test UI without hitting model quota
MOCK_MODE=false

# --- Distributed Agent Card URLs ---
# Used by Orchestrator to find sub-agents
# Format: http://localhost:PORT/a2a/agent/.well-known/agent-card.json
RESEARCH_A_AGENT_CARD_URL=http://localhost:8001/a2a/agent/.well-known/agent-card.json
RESEARCH_B_AGENT_CARD_URL=http://localhost:8002/a2a/agent/.well-known/agent-card.json
RESEARCH_C_AGENT_CARD_URL=http://localhost:8003/a2a/agent/.well-known/agent-card.json
SYNTHESIZER_AGENT_CARD_URL=http://localhost:8004/a2a/agent/.well-known/agent-card.json
