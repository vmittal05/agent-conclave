# Core GCP
GCP_PROJECT_ID=your-project-id
GCP_REGION=asia-south1
GCP_FIRESTORE_PROJECT_ID=your-project-id
GCP_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Firestore (Session State)
# FIRESTORE_EMULATOR_HOST=localhost:8080

# Cloud SQL (Postgres - Citations)
CLOUD_SQL_INSTANCE_CONNECTION_NAME=project:region:instance
CLOUD_SQL_DB_NAME=council_db
CLOUD_SQL_DB_USER=postgres
CLOUD_SQL_DB_PASSWORD=your-password

# LLM / LiteLLM / Models
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=your-litellm-key
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-...
GEMINI_API_KEY=...

# Model Routes
LITELLM_ROUTE_RESEARCH_A=claude-3.7-sonnet
LITELLM_ROUTE_RESEARCH_B=gpt-5.2
LITELLM_ROUTE_RESEARCH_C=gemini-2.5-pro
LITELLM_ROUTE_SYNTHESIZER=gpt-5.2

# MCP Servers
MCP_SEARCH_SERVER_URL=http://localhost:8001
MCP_TASKCAL_SERVER_URL=http://localhost:8002
MCP_GDEV_DOCS_SERVER_URL=http://localhost:8003
MCP_DB_SERVER_URL=http://localhost:8004

# App / Orchestration
COUNCIL_TOTAL_MODELS=3
LANGGRAPH_STORE_BACKEND=firestore
ADK_LOG_LEVEL=INFO
